build:linux --cxxopt=-std=c++20
build:linux --cxxopt=-Wall
build:linux --cxxopt=-Wextra
build:linux --cxxopt=-Wpedantic
build:linux --cxxopt=-Werror
# Keep project warnings fatal without imposing that policy on dependencies.
build:linux --per_file_copt=external/.*@-Wno-error
build:linux --cxxopt=-O3
build:linux --sandbox_add_mount_pair=/tmp

build:macos --cxxopt=-std=c++20
build:macos --cxxopt=-Wall
build:macos --cxxopt=-Wextra
build:macos --cxxopt=-Wpedantic
build:macos --cxxopt=-Werror
# Keep project warnings fatal without imposing that policy on dependencies.
build:macos --per_file_copt=external/.*@-Wno-error
build:macos --cxxopt=-Wno-error=nested-anon-types
build:macos --cxxopt=-Wno-error=zero-length-array
build:macos --cxxopt=-O3
build:macos --sandbox_add_mount_pair=/var/tmp

build:windows --cxxopt=/std:c++20
build:windows --cxxopt=/W4
build:windows --cxxopt=/O2
build:windows --cxxopt=/utf-8
build:windows --sandbox_add_mount_pair=C:\Temp

build -c opt

build:fp64 --define=clqr_precision=fp64
build:fp32 --define=clqr_precision=fp32

# Keep CUDA optional for ordinary CPU builds. Native CUDA targets become
# compatible only when --config=cuda is selected.
build --@rules_cuda//cuda:enable=false
build:cuda --@rules_cuda//cuda:enable=true
build:cuda --@rules_cuda//cuda:compiler=nvcc

# Friendly aliases for the rules_cuda architecture flag and the four validated
# (1--16) dense-workspace capacities.
common --flag_alias=cuda_archs=@rules_cuda//cuda:archs
common --flag_alias=cuda_max_state_dimension=//:cuda_max_state_dimension
common --flag_alias=cuda_max_control_dimension=//:cuda_max_control_dimension
common --flag_alias=cuda_max_mixed_constraints=//:cuda_max_mixed_constraints
common --flag_alias=cuda_max_state_constraints=//:cuda_max_state_constraints

# Benchmark capacities match n=8, m=4, and two constraints of each kind.
build:cuda-benchmark --config=cuda
build:cuda-benchmark --cuda_max_state_dimension=8
build:cuda-benchmark --cuda_max_control_dimension=4
build:cuda-benchmark --cuda_max_mixed_constraints=2
build:cuda-benchmark --cuda_max_state_constraints=2

common --enable_platform_specific_config

# Set minimum supported MacOS version to 11.0.
build:macos --macos_minimum_os=11.0

build:debug -c dbg
build:debug --cxxopt=-gfull
build:debug --cxxopt=-O0
build:debug --spawn_strategy=local

build:asan -c dbg
build:asan --copt=-fsanitize=address
build:asan --copt=-g
build:asan --copt=-O0
build:asan --spawn_strategy=local
build:asan --copt=-fno-omit-frame-pointer
build:asan --linkopt=-fsanitize=address

build:msan -c dbg
build:msan --copt=-fsanitize=memory
build:msan --copt=-g
build:msan --copt=-O0
build:msan --spawn_strategy=local
build:msan --copt=-fno-omit-frame-pointer
build:msan --linkopt=-fsanitize=memory

build:ubsan -c dbg
build:ubsan --copt=-fsanitize=undefined
build:ubsan --copt=-g
build:ubsan --copt=-O0
build:ubsan --spawn_strategy=local
build:ubsan --copt=-fno-omit-frame-pointer
build:ubsan --linkopt=-fsanitize=undefined
